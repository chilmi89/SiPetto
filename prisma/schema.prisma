generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model categories {
  id                String              @id @default(uuid()) @db.Uuid
  profile_id        String?             @db.Uuid
  name              String              @db.VarChar(100)
  type              String              @db.VarChar(20)
  created_at        DateTime?           @default(now()) @db.Timestamptz(6)
  profiles          profiles?           @relation(fields: [profile_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  transaction_items transaction_items[]

  @@unique([profile_id, name, type])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model payment_methods {
  id                String              @id @default(uuid()) @db.Uuid
  profile_id        String?             @db.Uuid
  name              String              @db.VarChar(50)
  is_active         Boolean?            @default(true)
  created_at        DateTime?           @default(now()) @db.Timestamptz(6)
  profiles          profiles?           @relation(fields: [profile_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  transaction_items transaction_items[]

  @@unique([profile_id, name])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model permissions {
  id               String             @id @default(uuid()) @db.Uuid
  name             String             @unique @db.VarChar(100)
  created_at       DateTime?          @default(now()) @db.Timestamptz(6)
  role_permissions role_permissions[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model profiles {
  id                 String               @id @default(uuid()) @db.Uuid
  role_id            String?              @db.Uuid
  email              String               @unique @db.VarChar(255)
  full_name          String?              @db.VarChar(255)
  business_name      String?              @db.VarChar(255)
  phone_number       String?              @db.VarChar(20)
  address            String?
  avatar_url         String?
  banner_url         String?
  bio                String?
  password           String?              @db.VarChar(255)
  is_active          Boolean?             @default(true)
  metadata           Json?                @default("{}")
  created_at         DateTime?            @default(now()) @db.Timestamptz(6)
  updated_at         DateTime?            @default(now()) @db.Timestamptz(6)
  categories         categories[]
  payment_methods    payment_methods[]
  roles              roles?               @relation(fields: [role_id], references: [id], onUpdate: NoAction)
  transaction_groups transaction_groups[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model role_permissions {
  role_id       String      @db.Uuid
  permission_id String      @db.Uuid
  permissions   permissions @relation(fields: [permission_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  roles         roles       @relation(fields: [role_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([role_id, permission_id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model roles {
  id               String             @id @default(uuid()) @db.Uuid
  name             String             @unique @db.VarChar(50)
  created_at       DateTime?          @default(now()) @db.Timestamptz(6)
  profiles         profiles[]
  role_permissions role_permissions[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model transaction_attachments {
  id                 String              @id @default(uuid()) @db.Uuid
  group_id           String?             @db.Uuid
  file_url           String
  created_at         DateTime?           @default(now()) @db.Timestamptz(6)
  transaction_groups transaction_groups? @relation(fields: [group_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model transaction_groups {
  id                      String                    @id @default(uuid()) @db.Uuid
  profile_id              String?                   @db.Uuid
  reference_number        String?                   @unique @db.VarChar(100)
  transaction_date        DateTime?                 @default(dbgenerated("CURRENT_DATE")) @db.Date
  total_income            Decimal?                  @default(0) @db.Decimal(15, 2)
  total_expense           Decimal?                  @default(0) @db.Decimal(15, 2)
  net_balance             Decimal?                  @default(0) @db.Decimal(15, 2)
  description             String?
  created_at              DateTime?                 @default(now()) @db.Timestamptz(6)
  transaction_attachments transaction_attachments[]
  profiles                profiles?                 @relation(fields: [profile_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  transaction_items       transaction_items[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model transaction_items {
  id                 String              @id @default(uuid()) @db.Uuid
  group_id           String?             @db.Uuid
  category_id        String?             @db.Uuid
  payment_method_id  String?             @db.Uuid
  type               String              @db.VarChar(20)
  name               String?             @db.VarChar(255)
  amount             Decimal?            @default(0) @db.Decimal(15, 2)
  created_at         DateTime?           @default(now()) @db.Timestamptz(6)
  categories         categories?         @relation(fields: [category_id], references: [id], onUpdate: NoAction)
  transaction_groups transaction_groups? @relation(fields: [group_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  payment_methods    payment_methods?    @relation(fields: [payment_method_id], references: [id], onUpdate: NoAction)
}
